# === Database ===
DB_PASSWORD=change-me-to-a-strong-password

# === Security ===
JWT_SECRET=change-me-to-a-random-secret
ADMIN_PASSWORD=change-me-superadmin-password

# === Frontend URL (used for CORS and password-reset emails) ===
FRONTEND_URL=https://yourdomain.com

# === SMTP (optional – needed for password reset emails) ===
SMTP_HOST=
SMTP_PORT=465
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=Audio Upload <noreply@yourdomain.com>
SMTP_SECURE=true
